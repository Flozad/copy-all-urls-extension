{
  "name": "Umbrella - Copy All URLs",
  "version": "1.12.1",
  "manifest_version": 3,
  "description": "Save and restore browser tabs instantly. Copy URLs in multiple formats, paste to reopen tabs.",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_title": "Copy and paste browser tabs"
  },
  "permissions": [
    "tabs",
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "contextMenus",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "commands": {
    "copy-urls": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Copy URLs from all open tabs"
    },
    "paste-urls": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Paste URLs to open them in new tabs"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
